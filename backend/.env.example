# SQLite by default; swap for Postgres in production, e.g.:
# DATABASE_URL=postgresql+psycopg2://user:password@host:5432/url_inspector
DATABASE_URL=sqlite:///./url_inspector.db

REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Optional: enables real Google Safe Browsing lookups. Get a free key at
# https://developers.google.com/safe-browsing/v4/get-started
GOOGLE_SAFE_BROWSING_API_KEY=

CACHE_TTL_SECONDS=3600
RATE_LIMIT_INSPECT=5/minute
CORS_ORIGINS=*
